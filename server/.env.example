# MongoDB Atlas
# Option 1: SRV (ưu tiên nếu DNS hỗ trợ)
#   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ultraviewer
#
# Option 2: Direct connection (nếu không resolve được SRV)
#   mongodb://<user>:<password>@host1:27017,host2:27017,host3:27017/ultraviewer?ssl=true&authSource=admin
#
# ⚠️ Nếu password có ký tự đặc biệt (@, :, /, %, #), phải URL-encode:
#   @ → %40   : → %3A   / → %2F   % → %25   # → %23

MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/ultraviewer

# JWT Secret (tối thiểu 32 ký tự)
JWT_SECRET=thay-bang-chuoi-ngau-nhien-it-nhat-32-ky-tu

# Server port
PORT=5000

# Frontend URL
CLIENT_URL=http://localhost:3000
